#:kivy 1.11.1
#:import get_color_from_hex kivy.utils.get_color_from_hex
<Interface>:
    Label:
        text: 'Sentinel Drive-Assist'
        font_name: "SentinelFont"
        font_size: '42sp'
        bold: True
        # Use pos_hint for responsive placement
        pos_hint: {'center_x': 0.5, 'top': 0.92}
        size_hint_y: None
        height: self.texture_size[1]

    FailSafeButton:
        pos_hint: {'center_x': 0.35, 'center_y': 0.55}
        size_hint: None, None

        size: "250dp", "250dp"
        on_press: root.on_failsafe_press()

    BoxLayout:
        orientation: 'vertical'
        pos_hint: {'center_x': 0.72, 'center_y': 0.55}
        size_hint: None, None
        size: "300dp", "380dp"
        padding: 0

        # Blue Background
        canvas.before:
            Color:
                rgba: get_color_from_hex("#7096D1")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]

        # Header
        Label:
            text: "Sound Library"
            font_name: "SentinelFont"
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: "60dp" # Fixed height for header

        # Divider Line
        Widget:
            size_hint_y: None
            height: "2dp"
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.5
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, self.height

        # List Items Container
        BoxLayout:
            orientation: 'vertical'
            spacing: "10dp"
            padding: ["10dp", "10dp", "10dp", "10dp"]

            SoundItem:
                text: "Alert Sound #1"
            SoundItem:
                text: "Alert Sound #2"
            SoundItem:
                text: "Alert Sound #3"
            SoundItem:
                text: "Alert Sound #4"
            SoundItem:
                text: "Alert Sound #5"

            Widget:
                size_hint_y: 1

    # 4. SLIDER CONTROL AREA
    BoxLayout:
        orientation: 'horizontal'
        size_hint: None, None
        size: "600dp", "60dp"
        pos_hint: {'center_x': 0.5, 'y': 0.08}
        spacing: "20dp"

        Image:
            source: '../icons/mute.png'
            size_hint_x: None
            width: "40dp"
            allow_stretch: True

        Slider:
            id: vol_slider
            min: 0
            max: 100
            value: 50
            step: 1
            value_track: True
            value_track_color: get_color_from_hex("#7096D1")
            cursor_size: ("25dp", "25dp")
            on_value: root.on_slider_value_change(self, self.value)

        Image:
            source: '../icons/music.png'
            size_hint_x: None
            width: "40dp"
            allow_stretch: True


<FailSafeButton>:
    orientation: 'vertical'
    padding: "20dp"
    spacing: "5dp"

    canvas.before:
        Color:
            rgba: get_color_from_hex("#5A7CB0") if self.state == 'down' else get_color_from_hex("#7096D1")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [30,]
        Color:
            rgba: 0, 0, 0, 0.3
        RoundedRectangle:
            pos: self.x - 4, self.y - 4
            size: self.size
            radius: [30,]

    Image:
        source: '../icons/mute.png'
        size_hint_y: 0.7
        allow_stretch: True

    Label:
        text: "Fail-safe"
        font_name: "SentinelFont"
        font_size: '32sp'
        bold: True
        size_hint_y: 0.3

<SoundItem@BoxLayout>:
    canvas.after:
        Color:
            rgba: 1, 1, 1, 0.3
        Line:
            points: [self.x, self.y, self.right, self.y]
            width: 1

    text: ""
    orientation: 'horizontal'

    size_hint_y: None
    height: "45dp"

    Image:
        source: '../icons/music.png'
        size_hint_x: None
        width: "30dp"
        allow_stretch: True
        pos_hint: {'center_y': 0.5}

    Label:
        text: root.text
        font_name: "SentinelFont"
        font_size: '18sp'
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        bold: True
        padding_x: "15dp"
        size_hint_x: 1