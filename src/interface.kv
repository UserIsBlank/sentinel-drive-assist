#:kivy 1.11.1
#:import get_color_from_hex kivy.utils.get_color_from_hex

<Interface>:
    Label:
        text: 'Sentinel Drive-Assist'
        font_name: "SentinelFont"
        font_size: '42sp'
        bold: True
        pos_hint: {'center_x': 0.5, 'top': 0.92}
        size_hint_y: None
        height: self.texture_size[1]

    BoxLayout:
        orientation: 'vertical'
        size_hint: None, None
        size: "200dp", "440dp"
        pos_hint: {'center_x': 0.25, 'center_y': 0.55}
        spacing: "20dp"

        DetectionButton:
            size_hint: 1, 1

        FailSafeButton:
            size_hint: 1, 1
            on_press: root.on_failsafe_press()

        # Sensitivity Control
        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, None
            height: "70dp"
            spacing: "6dp"

            Label:
                text: "Sensitivity"
                font_name: "SentinelFont"
                font_size: '14sp'
                size_hint_y: None
                height: "18dp"
                color: 1, 1, 1, 0.85

            BoxLayout:
                orientation: 'horizontal'
                spacing: "4dp"

                Button:
                    text: "Low"
                    font_size: '13sp'
                    background_color: (0.4, 0.8, 0.4, 1) if app.sensitivity == 'conservative' else (0.4, 0.4, 0.55, 1)
                    on_press: app.set_sensitivity('conservative')

                Button:
                    text: "Med"
                    font_size: '13sp'
                    background_color: (0.4, 0.8, 0.4, 1) if app.sensitivity == 'default' else (0.4, 0.4, 0.55, 1)
                    on_press: app.set_sensitivity('default')

                Button:
                    text: "High"
                    font_size: '13sp'
                    background_color: (0.4, 0.8, 0.4, 1) if app.sensitivity == 'aggressive' else (0.4, 0.4, 0.55, 1)
                    on_press: app.set_sensitivity('aggressive')

    BoxLayout:
        orientation: 'vertical'
        pos_hint: {'center_x': 0.72, 'center_y': 0.55}
        size_hint: None, None
        size: "300dp", "380dp"
        padding: 0

        # Blue Background
        canvas.before:
            Color:
                rgba: get_color_from_hex("#7096D1")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [20,]

        # Header
        Label:
            text: "Sound Library"
            font_name: "SentinelFont"
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: "60dp"

        # Divider Line
        Widget:
            size_hint_y: None
            height: "2dp"
            canvas:
                Color:
                    rgba: 1, 1, 1, 0.5
                Rectangle:
                    pos: self.x, self.y
                    size: self.width, self.height

        # List Items Container
        BoxLayout:
            orientation: 'vertical'
            spacing: "10dp"
            padding: ["10dp", "10dp", "10dp", "10dp"]

            SoundItem:
                text: "Alert Sound #1"
                sound_file: '../audio/alert1.mp3'
            SoundItem:
                text: "Alert Sound #2"
                sound_file: '../audio/alert2.mp3'
            SoundItem:
                text: "Alert Sound #3"
                sound_file: '../audio/alert3.mp3'
            SoundItem:
                text: "Alert Sound #4"
                sound_file: '../audio/alert4.mp3'
            SoundItem:
                text: "Alert Sound #5"
                sound_file: '../audio/alert5.mp3'

            Widget:
                size_hint_y: 1

    # Volume Slider Control
    BoxLayout:
        orientation: 'horizontal'
        size_hint: None, None
        size: "600dp", "60dp"
        pos_hint: {'center_x': 0.5, 'y': 0.08}
        spacing: "20dp"

        # MUTE BUTTON
        ImageButton:
            size_hint_x: None
            width: "40dp"
            opacity: 0.5 if app.audio_manager.is_muted else 1.0
            on_press: app.audio_manager.toggle_mute()

            Image:
                source: '../icons/mute.png'
                allow_stretch: True
                center_x: self.parent.center_x
                center_y: self.parent.center_y

        # VOLUME SLIDER
        Slider:
            id: vol_slider
            min: 0
            max: 100
            value: 50
            step: 1
            value_track: True
            value_track_color: get_color_from_hex("#7096D1")
            cursor_size: ("25dp", "25dp")
            on_value: app.audio_manager.set_volume(self.value)

        Image:
            source: '../icons/music.png'
            size_hint_x: None
            width: "40dp"
            allow_stretch: True


<FailSafeButton>:
    orientation: 'vertical'
    padding: "20dp"
    spacing: "5dp"

    canvas.before:
        Color:
            rgba: get_color_from_hex("#5A7CB0") if self.state == 'down' else get_color_from_hex("#7096D1")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [30,]
        Color:
            rgba: 0, 0, 0, 0.3
        RoundedRectangle:
            pos: self.x - 4, self.y - 4
            size: self.size
            radius: [30,]

    Image:
        source: '../icons/mute.png'
        size_hint_y: 0.7
        allow_stretch: True

    Label:
        text: "Fail-safe"
        font_name: "SentinelFont"
        font_size: '32sp'
        bold: True
        size_hint_y: 0.3

<DetectionButton>:
    orientation: 'vertical'
    padding: "20dp"
    spacing: "5dp"

    canvas.before:
        Color:
            # Green if Active, Red if Inactive
            rgba: (0.4, 0.8, 0.4, 1) if app.detection_active else (0.8, 0.4, 0.4, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [30,]
        Color:
            rgba: 0, 0, 0, 0.3
        RoundedRectangle:
            pos: self.x - 4, self.y - 4
            size: self.size
            radius: [30,]

    Image:
        source: '../icons/coffee.png'
        size_hint_y: 0.7
        allow_stretch: True

    Label:
        # Dynamic Text
        text: "DETECTION: ON" if app.detection_active else "DETECTION: OFF"
        font_name: "SentinelFont"
        font_size: '22sp' # Reduced slightly to fit
        bold: True
        size_hint_y: 0.3

<SoundItem>:
    is_selected: True if app.audio_manager.selected_file == self.sound_file else False

    canvas.after:
        Color:
            rgba: 1, 1, 1, 0.3
        Line:
            points: [self.x, self.y, self.right, self.y]
            width: 1

    canvas.before:
        Color:
            rgba: (0.4, 0.8, 0.4, 0.4) if self.is_selected else (0, 0, 0, 0)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10,]

    text: ""
    orientation: 'horizontal'
    size_hint_y: None
    height: "45dp"

    Label:
        text: u"✓" if root.is_selected else ""
        font_size: '20sp'
        color: 0.4, 1, 0.4, 1
        size_hint_x: None
        width: "30dp" if root.is_selected else "0dp"
        opacity: 1 if root.is_selected else 0

    Image:
        source: '../icons/music.png'
        size_hint_x: None
        width: "30dp"
        allow_stretch: True
        pos_hint: {'center_y': 0.5}

    Label:
        text: root.text
        font_name: "SentinelFont"
        font_size: '18sp'
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        bold: True
        padding_x: "15dp"
        size_hint_x: 1